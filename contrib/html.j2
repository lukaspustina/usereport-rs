<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <title>Use Report - {{ context.hostname }} on {{ context.date_time | rfc2822 }}</title>

    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; margin: 0; color: #212529; }
        .container-fluid { width: 100%; padding: 1rem 1.5rem; box-sizing: border-box; }
        h1 { font-size: 2rem; margin: 1rem 0 0.5rem 0; }
        h2 { font-size: 1.5rem; margin: 1.5rem 0 0.5rem 0; border-bottom: 1px solid #dee2e6; padding-bottom: 0.25rem; }
        h3 { font-size: 1.2rem; margin: 0.5rem 0; }
        ul.list-group { list-style: none; padding: 0; margin: 0 0 1rem 0; }
        li.list-group-item { border: 1px solid #dee2e6; padding: 0.6rem 0.8rem; margin-bottom: -1px; background: #fff; }
        li.list-group-item:first-child { border-top-left-radius: 0.25rem; border-top-right-radius: 0.25rem; }
        li.list-group-item:last-child { border-bottom-left-radius: 0.25rem; border-bottom-right-radius: 0.25rem; margin-bottom: 0; }
        .border { border: 1px solid #dee2e6; }
        .border-secondary { border-color: #6c757d; }
        .rounded { border-radius: 0.25rem; }
        .text-warning { color: #b8860b; }
        .text-danger { color: #b22222; }
        pre { background: #f8f9fa; padding: 0.6rem; overflow-x: auto; margin: 0.4rem 0; }
        code { background: #f1f3f5; padding: 0 0.25rem; border-radius: 0.2rem; font-family: SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
        small { color: #495057; }
        a { color: #0066cc; text-decoration: none; }
        a:hover { text-decoration: underline; }
        hr { border: 0; border-top: 1px solid #dee2e6; margin: 1.5rem 0; }
    </style>
</head>
<body>
<div class="container-fluid">
    <h1>Use Report - {{ context.hostname }} on {{ context.date_time | rfc2822 }}</h1>
    <p>
    <ul class="list-group">
        <li class="list-group-item">Date: <code>{{ context.date_time | rfc2822 }}</code></li>
        <li class="list-group-item">Hostname: <code>{{ context.hostname }}</code></li>
        <li class="list-group-item">Host OS: <code>{{ context.uname }}</code></li>
    </ul>
    </p>
    <h2>Run Configuration</h2>
    <p>
    <ul class="list-group">
        {% for key, value in context.more %}
            <li class="list-group-item">{{ key }}: {{ value }}</li>
        {% endfor %}
        <li class="list-group-item">Repetitions: {{ repetitions }}</li>
        <li class="list-group-item">Parallelism: {{ max_parallel_commands }}</li>
    </ul>
    </p>

    <div>
        <h2>Host Information</h2>
        <ul class="list-group">
            {% for result in hostinfo_results %}
                <li class="list-group-item">
                    {% if result.Success is defined %}
                        {% set s = result.Success %}
                        <h3>{% if s.command.title %}{{ s.command.title }}{% else %}{{ s.command.name }}{% endif %}</h3>
                        <div class="border border-secondary rounded">
                            <pre>{{ s.stdout }}</pre>
                        </div>
                        <p>
                        <small>
                            {% if s.command.description %}
                                <p>{{ s.command.description | e | replace("\n", "<br/>") | safe }}</p>
                            {% endif %}
                            Command: <code>{{ s.command.command }}</code> [{{ s.run_time_ms }} ms]<br/>
                            {% for link in s.command.links %}[<a href="{{ link.url }}">{{ link.name }}</a>] {% endfor %}
                        </small>
                        </p>
                    {% endif %}

                    {% if result.Failed is defined %}
                        {% set s = result.Failed %}
                        <h3 class="text-warning">{% if s.command.title %}{{ s.command.title }}{% else %}{{ s.command.name }}{% endif %}: Failed</h3>
                        <div class="border border-secondary rounded">
                            <pre>{{ s.stdout }}</pre>
                        </div>
                        <p>
                        <small>
                            {% if s.command.description %}
                                <p>{{ s.command.description | e | replace("\n", "<br/>") | safe }}</p>
                            {% endif %}
                            Command: <code>{{ s.command.command }}</code> [{{ s.run_time_ms }} ms]<br/>
                            {% for link in s.command.links %}[<a href="{{ link.url }}">{{ link.name }}</a>] {% endfor %}
                        </small>
                        </p>
                    {% endif %}

                    {% if result.Timeout is defined %}
                        {% set s = result.Timeout %}
                        <h3 class="text-danger">{% if s.command.title %}{{ s.command.title }}{% else %}{{ s.command.name }}{% endif %}: Timed out</h3>
                        <p>
                            <small>
                                Command: <code>{{ s.command.command }}</code> [{{ s.run_time_ms }} ms]<br/>
                            </small>
                        </p>
                    {% endif %}

                    {% if result.Error is defined %}
                        {% set s = result.Error %}
                        <h3 class="text-danger">{% if s.command.title %}{{ s.command.title }}{% else %}{{ s.command.name }}{% endif %}: Error</h3>
                        <p>
                            Reason: {{ s.reason }}<br/>
                            <small>
                                Command: <code>{{ s.command.command }}</code> [{{ s.run_time_ms }} ms]<br/>
                            </small>
                        </p>
                    {% endif %}

                    {# SkippedMissing is intentionally not rendered here:
                       per SDD §27 the command's section is omitted from
                       Markdown/HTML output entirely. A future info finding
                       (Phase 1+) names the missing binary. #}
                </li>
            {% endfor %}
        </ul>
    </div>

    <hr/>

    {% for run in command_results %}
        <h2>Command Results - Run {{ loop.index }}</h2>
        <ul class="list-group">
            {% for result in run %}
                <li class="list-group-item">
                    {% if result.Success is defined %}
                        {% set s = result.Success %}
                        <h3>{% if s.command.title %}{{ s.command.title }}{% else %}{{ s.command.name }}{% endif %}</h3>
                        <div class="border border-secondary rounded">
                            <pre>{{ s.stdout }}</pre>
                        </div>
                        <p>
                        <small>
                            {% if s.command.description %}
                                <p>{{ s.command.description | e | replace("\n", "<br/>") | safe }}</p>
                            {% endif %}
                            Command: <code>{{ s.command.command }}</code> [{{ s.run_time_ms }} ms]<br/>
                            {% for link in s.command.links %}[<a href="{{ link.url }}">{{ link.name }}</a>] {% endfor %}
                        </small>
                        </p>
                    {% endif %}

                    {% if result.Failed is defined %}
                        {% set s = result.Failed %}
                        <h3 class="text-warning">{% if s.command.title %}{{ s.command.title }}{% else %}{{ s.command.name }}{% endif %}: Failed</h3>
                        <div class="border border-secondary rounded">
                            <pre>{{ s.stdout }}</pre>
                        </div>
                        <p>
                        <small>
                            {% if s.command.description %}
                                <p>{{ s.command.description | e | replace("\n", "<br/>") | safe }}</p>
                            {% endif %}
                            Command: <code>{{ s.command.command }}</code> [{{ s.run_time_ms }} ms]<br/>
                            {% for link in s.command.links %}[<a href="{{ link.url }}">{{ link.name }}</a>] {% endfor %}
                        </small>
                        </p>
                    {% endif %}

                    {% if result.Timeout is defined %}
                        {% set s = result.Timeout %}
                        <h3 class="text-danger">{% if s.command.title %}{{ s.command.title }}{% else %}{{ s.command.name }}{% endif %}: Timed out</h3>
                        <p>
                            <small>
                                Command: <code>{{ s.command.command }}</code> [{{ s.run_time_ms }} ms]<br/>
                            </small>
                        </p>
                    {% endif %}

                    {% if result.Error is defined %}
                        {% set s = result.Error %}
                        <h3 class="text-danger">{% if s.command.title %}{{ s.command.title }}{% else %}{{ s.command.name }}{% endif %}: Error</h3>
                        <p>
                            Reason: {{ s.reason }}<br/>
                            <small>
                                Command: <code>{{ s.command.command }}</code> [{{ s.run_time_ms }} ms]<br/>
                            </small>
                        </p>
                    {% endif %}

                    {# SkippedMissing is intentionally not rendered here:
                       per SDD §27 the command's section is omitted from
                       Markdown/HTML output entirely. A future info finding
                       (Phase 1+) names the missing binary. #}
                </li>
            {% endfor %}
        </ul>
    {% endfor %}

    <hr/>

    <small>Please see <a
            href="https://medium.com/netflix-techblog/linux-performance-analysis-in-60-000-milliseconds-accc10403c55">Linux
        Performance Analysis in 60,000 Milliseconds</a> for details about the individual reports.</small>
</div>
</body>
</html>
