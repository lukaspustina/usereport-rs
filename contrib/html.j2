<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <title>usereport — {{ context.hostname | e }} on {{ context.date_time | rfc2822 }}</title>

    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; margin: 0; color: #212529; }
        .container-fluid { width: 100%; padding: 1rem 1.5rem; box-sizing: border-box; }
        h1 { font-size: 2rem; margin: 1rem 0 0.5rem 0; }
        h2 { font-size: 1.5rem; margin: 1.5rem 0 0.5rem 0; border-bottom: 1px solid #dee2e6; padding-bottom: 0.25rem; }
        h3 { font-size: 1.2rem; margin: 0.5rem 0; }
        ul.list-group { list-style: none; padding: 0; margin: 0 0 1rem 0; }
        li.list-group-item { border: 1px solid #dee2e6; padding: 0.6rem 0.8rem; margin-bottom: -1px; background: #fff; }
        li.list-group-item:first-child { border-top-left-radius: 0.25rem; border-top-right-radius: 0.25rem; }
        li.list-group-item:last-child { border-bottom-left-radius: 0.25rem; border-bottom-right-radius: 0.25rem; margin-bottom: 0; }
        .border { border: 1px solid #dee2e6; }
        .border-secondary { border-color: #6c757d; }
        .rounded { border-radius: 0.25rem; }
        .text-warning { color: #b8860b; }
        .text-danger { color: #b22222; }
        pre { background: #f8f9fa; padding: 0.6rem; overflow-x: auto; margin: 0.4rem 0; }
        code { background: #f1f3f5; padding: 0 0.25rem; border-radius: 0.2rem; font-family: SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
        small { color: #495057; }
        a { color: #0066cc; text-decoration: none; }
        a:hover { text-decoration: underline; }
        hr { border: 0; border-top: 1px solid #dee2e6; margin: 1.5rem 0; }
    </style>
</head>
<body>
<div class="container-fluid">
    <h1>Use Report — {{ context.hostname | e }} on {{ context.date_time | rfc2822 }}</h1>

    <h2>Summary</h2>
    <ul class="list-group">
        <li class="list-group-item">Host: <code>{{ context.hostname | e }}</code></li>
        <li class="list-group-item">Kernel: <code>{{ context.uname | e }}</code></li>
        <li class="list-group-item">Date: <code>{{ context.date_time | rfc2822 }}</code></li>
        <li class="list-group-item">Repetitions: {{ repetitions }}</li>
        <li class="list-group-item">Parallelism: {{ max_parallel_commands }}</li>
        {% if findings %}
        <li class="list-group-item">Top concern: <strong>{{ findings[0].severity | upper }}</strong> — {{ findings[0].summary | e }}</li>
        {% endif %}
    </ul>

    {%- set ns_ev = namespace(evidence_cmds=[]) %}
    {%- for f in findings %}
    {%- for ev in f.evidence %}
    {%- for cmd_name in ev.source_commands %}
    {%- if cmd_name not in ns_ev.evidence_cmds %}
    {%- set ns_ev.evidence_cmds = ns_ev.evidence_cmds + [cmd_name] %}
    {%- endif %}
    {%- endfor %}
    {%- endfor %}
    {%- endfor %}

    <h2>Vital Signs</h2>
    <table style="border-collapse:collapse;width:100%;margin-bottom:1rem;">
        <thead><tr><th style="text-align:left;padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Resource</th><th style="text-align:left;padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Value</th><th style="text-align:left;padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Severity</th></tr></thead>
        <tbody>
        {%- set cpu_profiled = vital_signs.cpu.iowait_pct is not none or vital_signs.cpu.severity is not none %}
        <tr><td style="padding:0.4rem 0.8rem;">CPU</td><td style="padding:0.4rem 0.8rem;">{% if vital_signs.cpu.iowait_pct is not none %}iowait {{ vital_signs.cpu.iowait_pct | round(1) }}%{% elif cpu_profiled %}—{% else %}no data{% endif %}</td><td style="padding:0.4rem 0.8rem;">{% if vital_signs.cpu.severity == "Crit" %}<span class="text-danger">CRIT</span>{% elif vital_signs.cpu.severity == "Warn" %}<span class="text-warning">WARN</span>{% elif cpu_profiled %}—{% else %}no data{% endif %}</td></tr>
        {%- set mem_profiled = vital_signs.memory.used_pct is not none or vital_signs.memory.severity is not none %}
        <tr><td style="padding:0.4rem 0.8rem;">Memory</td><td style="padding:0.4rem 0.8rem;">{% if vital_signs.memory.used_pct is not none %}used {{ vital_signs.memory.used_pct | round(1) }}%{% elif mem_profiled %}—{% else %}no data{% endif %}</td><td style="padding:0.4rem 0.8rem;">{% if vital_signs.memory.severity == "Crit" %}<span class="text-danger">CRIT</span>{% elif vital_signs.memory.severity == "Warn" %}<span class="text-warning">WARN</span>{% elif mem_profiled %}—{% else %}no data{% endif %}</td></tr>
        {%- set disk_profiled = vital_signs.disk.util_pct is not none or vital_signs.disk.severity is not none %}
        <tr><td style="padding:0.4rem 0.8rem;">Disk</td><td style="padding:0.4rem 0.8rem;">{% if vital_signs.disk.util_pct is not none %}util {{ vital_signs.disk.util_pct | round(1) }}%{% elif disk_profiled %}—{% else %}no data{% endif %}</td><td style="padding:0.4rem 0.8rem;">{% if vital_signs.disk.severity == "Crit" %}<span class="text-danger">CRIT</span>{% elif vital_signs.disk.severity == "Warn" %}<span class="text-warning">WARN</span>{% elif disk_profiled %}—{% else %}no data{% endif %}</td></tr>
        {%- set net_profiled = vital_signs.network.util_pct is not none or vital_signs.network.severity is not none %}
        <tr><td style="padding:0.4rem 0.8rem;">Network</td><td style="padding:0.4rem 0.8rem;">{% if vital_signs.network.util_pct is not none %}util {{ vital_signs.network.util_pct | round(1) }}%{% elif net_profiled %}—{% else %}no data{% endif %}</td><td style="padding:0.4rem 0.8rem;">{% if vital_signs.network.severity == "Crit" %}<span class="text-danger">CRIT</span>{% elif vital_signs.network.severity == "Warn" %}<span class="text-warning">WARN</span>{% elif net_profiled %}—{% else %}no data{% endif %}</td></tr>
        </tbody>
    </table>

    {%- if use_coverage %}
    <h2>USE Coverage</h2>
    <table style="border-collapse:collapse;width:100%;margin-bottom:1rem;">
        <thead><tr><th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Resource</th><th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Utilization</th><th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Saturation</th><th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Errors</th></tr></thead>
        <tbody>
        {%- for resource in ["cpu", "memory", "disk", "network"] %}
        {%- set util = use_coverage | selectattr("resource", "equalto", resource) | selectattr("aspect", "equalto", "utilization") | first %}
        {%- set sat  = use_coverage | selectattr("resource", "equalto", resource) | selectattr("aspect", "equalto", "saturation") | first %}
        {%- set err  = use_coverage | selectattr("resource", "equalto", resource) | selectattr("aspect", "equalto", "errors") | first %}
        <tr><td style="padding:0.4rem 0.8rem;">{{ resource }}</td><td style="padding:0.4rem 0.8rem;">{{ "✓" if util and util.covered else "✗" }}</td><td style="padding:0.4rem 0.8rem;">{{ "✓" if sat and sat.covered else "✗" }}</td><td style="padding:0.4rem 0.8rem;">{{ "✓" if err and err.covered else "✗" }}</td></tr>
        {%- endfor %}
        </tbody>
    </table>
    {%- endif %}

    {%- set ns_sk = namespace(has_skipped=false) %}
    {%- for run in command_results %}
    {%- for result in run %}
    {%- if result.SkippedMissing %}{% set ns_sk.has_skipped = true %}{% endif %}
    {%- endfor %}
    {%- endfor %}
    {%- if ns_sk.has_skipped %}
    <h2>Coverage Gaps</h2>
    <p><em>Some findings may be incomplete</em> — the tools below were not found on PATH. Run <code>usereport check</code> to verify tool availability.</p>
    <table style="border-collapse:collapse;width:100%;margin-bottom:1rem;">
        <thead><tr><th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Command</th><th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Missing Binary</th><th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Install</th></tr></thead>
        <tbody>
        {%- for run in command_results %}
        {%- for result in run %}
        {%- if result.SkippedMissing %}
        {%- set s = result.SkippedMissing %}
        <tr><td style="padding:0.4rem 0.8rem;"><code>{{ s.command.name | e }}</code></td><td style="padding:0.4rem 0.8rem;"><code>{{ s.binary | e }}</code></td><td style="padding:0.4rem 0.8rem;">{{ s.command.install_hint | e if s.command.install_hint else "—" }}</td></tr>
        {%- endif %}
        {%- endfor %}
        {%- endfor %}
        </tbody>
    </table>
    {%- endif %}

    {% if findings %}
    <h2>Findings</h2>
    <ul class="list-group">
        {% for f in findings %}
        <li class="list-group-item">
            <h3>
                {% if f.severity == "Crit" %}<span class="text-danger">[CRIT]</span>
                {% elif f.severity == "Warn" %}<span class="text-warning">[WARN]</span>
                {% else %}[INFO]
                {% endif %}
                {{ f.id | e }}
            </h3>
            <p>{{ f.summary | e }}</p>
            {% if f.evidence %}
            <p><small>Evidence:
                {% for e in f.evidence %}
                <code>{{ e.signal_id | e }}</code> = {{ e.observed | string }}
                {%- for sc in e.source_commands %} <a href="#cmd-{{ sc | e }}">[{{ sc | e }}]</a>{%- endfor -%}
                {%- if not loop.last %}, {% endif %}
                {% endfor %}
            </small></p>
            {% endif %}
            {% if f.suggest %}
            <p><small>Next steps:
                {% for cmd in f.suggest %}
                {%- set ns_s = namespace(found_name="") %}
                {%- for run in command_results %}
                {%- for result in run %}
                {%- if result.Success is defined and result.Success.command.command == cmd %}
                {%- set ns_s.found_name = result.Success.command.name %}
                {%- endif %}
                {%- endfor %}
                {%- endfor %}
                {%- if ns_s.found_name %}
                <a href="#cmd-{{ ns_s.found_name | e }}">{{ cmd | e }} ↓</a>
                {%- else %}
                <code>{{ cmd | e }}</code>
                {%- endif %}
                {%- if not loop.last %} · {% endif %}
                {% endfor %}
            </small></p>
            {% endif %}
        </li>
        {% endfor %}
    </ul>
    {% endif %}
    {%- if not findings %}
    <h2>Findings</h2>
    <p>No findings — all checks passed.</p>
    {%- endif %}

    {%- set fired_ids = findings | map(attribute="id") | list %}
    {%- set active_followups = followup_recommendations | selectattr("finding", "in", fired_ids) | list %}
    {%- if active_followups %}
    <h2>Where to investigate next</h2>
    <ul class="list-group">
    {%- for fu in active_followups %}
        <li class="list-group-item"><strong>{{ fu.recommend | e }}</strong> — {{ fu.reason | e }}</li>
    {%- endfor %}
    </ul>
    {%- endif %}

    {%- if checked_ok %}
    <h2>Healthy</h2>
    <p>The following signals were evaluated and found within normal thresholds:</p>
    <ul class="list-group">
    {%- for id in checked_ok %}
        <li class="list-group-item"><code>{{ id | e }}</code></li>
    {%- endfor %}
    </ul>
    {%- endif %}

    <h2>Run Configuration</h2>
    <p>
    <ul class="list-group">
        {% for key, value in context.more | items %}
            <li class="list-group-item">{{ key | e }}: {{ value | e }}</li>
        {% endfor %}
    </ul>
    </p>

    <div>
        <h2>Host Information</h2>
        <ul class="list-group">
            {% for result in hostinfo_results %}
                <li class="list-group-item">
                    {% if result.Success is defined %}
                        {% set s = result.Success %}
                        <h3>{% if s.command.title %}{{ s.command.title | e }}{% else %}{{ s.command.name | e }}{% endif %}</h3>
                        <div class="border border-secondary rounded">
                            <pre>{{ s.stdout | e }}</pre>
                        </div>
                        <p>
                        <small>
                            {% if s.command.description %}
                                <p>{{ s.command.description | e | replace("\n", "<br/>") | safe }}</p>
                            {% endif %}
                            Command: <code>{{ s.command.command | e }}</code> [{{ s.run_time_ms }} ms]<br/>
                            {% for link in s.command.links %}[<a href="{{ link.url | e }}">{{ link.name | e }}</a>] {% endfor %}
                        </small>
                        </p>
                    {% endif %}

                    {% if result.Failed is defined %}
                        {% set s = result.Failed %}
                        <h3 class="text-warning">{% if s.command.title %}{{ s.command.title | e }}{% else %}{{ s.command.name | e }}{% endif %}: Failed</h3>
                        <div class="border border-secondary rounded">
                            <pre>{{ s.stdout | e if s.stdout else "(no output — check if the binary requires elevated privileges)" }}</pre>
                        </div>
                        <p>
                        <small>
                            {% if s.command.description %}
                                <p>{{ s.command.description | e | replace("\n", "<br/>") | safe }}</p>
                            {% endif %}
                            Command: <code>{{ s.command.command | e }}</code> [{{ s.run_time_ms }} ms] — stdout + stderr combined<br/>
                            {% for link in s.command.links %}[<a href="{{ link.url | e }}">{{ link.name | e }}</a>] {% endfor %}
                        </small>
                        </p>
                    {% endif %}

                    {% if result.Timeout is defined %}
                        {% set s = result.Timeout %}
                        <h3 class="text-danger">{% if s.command.title %}{{ s.command.title | e }}{% else %}{{ s.command.name | e }}{% endif %}: Timed out</h3>
                        <p>
                            <small>
                                Command: <code>{{ s.command.command | e }}</code> [{{ s.run_time_ms }} ms]<br/>
                            </small>
                            <small>Increase the <code>timeout</code> for this command in your config if it is expected to take longer.</small>
                        </p>
                    {% endif %}

                    {% if result.Error is defined %}
                        {% set s = result.Error %}
                        <h3 class="text-danger">{% if s.command.title %}{{ s.command.title | e }}{% else %}{{ s.command.name | e }}{% endif %}: Error</h3>
                        <p>
                            Reason: {{ s.reason | e }}<br/>
                            <small>Run the command manually to investigate: <code>{{ s.command.command | e }}</code></small><br/>
                            <small>
                                Command: <code>{{ s.command.command | e }}</code> [{{ s.run_time_ms }} ms]<br/>
                            </small>
                        </p>
                    {% endif %}

                    {# SkippedMissing is intentionally not rendered here:
                       per SDD §27 the command's section is omitted from
                       Markdown/HTML output entirely. A future info finding
                       (Phase 1+) names the missing binary. #}
                </li>
            {% endfor %}
        </ul>
    </div>

    <hr/>

    {% for run in command_results %}
        <h2>Command Results{% if command_results | length > 1 %} — Run {{ loop.index }}{% endif %}</h2>
        {# Evidence commands rendered first (before details), then non-evidence in <details> #}
        <ul class="list-group">
        {% for result in run %}
        {%- if result.Success is defined and result.Success.command.name in ns_ev.evidence_cmds %}
            {% set s = result.Success %}
            {%- set ns_badge = namespace(ids=[]) %}
            {%- for f in findings %}
            {%- for ev in f.evidence %}
            {%- if s.command.name in ev.source_commands %}
            {%- set ns_badge.ids = ns_badge.ids + [f.id] %}
            {%- endif %}
            {%- endfor %}
            {%- endfor %}
            <li class="list-group-item" id="cmd-{{ s.command.name | e }}">
                <h3>{% if s.command.title %}{{ s.command.title | e }}{% else %}{{ s.command.name | e }}{% endif %}</h3>
                {% if ns_badge.ids %}<p><strong>Evidence for: {{ ns_badge.ids | join(", ") | e }}</strong></p>{% endif %}
                <div class="border border-secondary rounded"><pre>{{ s.stdout | e }}</pre></div>
                <p><small>
                    {% if s.command.description %}<p>{{ s.command.description | e | replace("\n", "<br/>") | safe }}</p>{% endif %}
                    Command: <code>{{ s.command.command | e }}</code> [{{ s.run_time_ms }} ms]<br/>
                    {% for link in s.command.links or [] %}[<a href="{{ link.url | e }}">{{ link.name | e }}</a>] {% endfor %}
                </small></p>
            </li>
        {%- endif %}
        {% endfor %}
        </ul>
        <details><summary>Full output ({{ run | length }} commands)</summary>
        <ul class="list-group">
        {% for result in run %}
        {%- if not (result.Success is defined and result.Success.command.name in ns_ev.evidence_cmds) %}
                <li class="list-group-item">
                    {% if result.Success is defined %}
                        {% set s = result.Success %}
                        <h3 id="cmd-{{ s.command.name | e }}">{% if s.command.title %}{{ s.command.title | e }}{% else %}{{ s.command.name | e }}{% endif %}</h3>
                        <div class="border border-secondary rounded">
                            <pre>{{ s.stdout | e }}</pre>
                        </div>
                        <p>
                        <small>
                            {% if s.command.description %}
                                <p>{{ s.command.description | e | replace("\n", "<br/>") | safe }}</p>
                            {% endif %}
                            Command: <code>{{ s.command.command | e }}</code> [{{ s.run_time_ms }} ms]<br/>
                            {% for link in s.command.links or [] %}[<a href="{{ link.url | e }}">{{ link.name | e }}</a>] {% endfor %}
                        </small>
                        </p>
                    {% endif %}

                    {% if result.Failed is defined %}
                        {% set s = result.Failed %}
                        <h3 id="cmd-{{ s.command.name | e }}" class="text-warning">{% if s.command.title %}{{ s.command.title | e }}{% else %}{{ s.command.name | e }}{% endif %}: Failed</h3>
                        <div class="border border-secondary rounded">
                            <pre>{{ s.stdout | e if s.stdout else "(no output — check if the binary requires elevated privileges)" }}</pre>
                        </div>
                        <p>
                        <small>
                            {% if s.command.description %}
                                <p>{{ s.command.description | e | replace("\n", "<br/>") | safe }}</p>
                            {% endif %}
                            Command: <code>{{ s.command.command | e }}</code> [{{ s.run_time_ms }} ms] — stdout + stderr combined<br/>
                            {% for link in s.command.links or [] %}[<a href="{{ link.url | e }}">{{ link.name | e }}</a>] {% endfor %}
                        </small>
                        </p>
                    {% endif %}

                    {% if result.Timeout is defined %}
                        {% set s = result.Timeout %}
                        <h3 id="cmd-{{ s.command.name | e }}" class="text-danger">{% if s.command.title %}{{ s.command.title | e }}{% else %}{{ s.command.name | e }}{% endif %}: Timed out</h3>
                        <p>
                            <small>
                                Command: <code>{{ s.command.command | e }}</code> [{{ s.run_time_ms }} ms]<br/>
                            </small>
                            <small>Increase the <code>timeout</code> for this command in your config if it is expected to take longer.</small>
                        </p>
                    {% endif %}

                    {% if result.Error is defined %}
                        {% set s = result.Error %}
                        <h3 id="cmd-{{ s.command.name | e }}" class="text-danger">{% if s.command.title %}{{ s.command.title | e }}{% else %}{{ s.command.name | e }}{% endif %}: Error</h3>
                        <p>
                            Reason: {{ s.reason | e }}<br/>
                            <small>Run the command manually to investigate: <code>{{ s.command.command | e }}</code></small><br/>
                            <small>
                                Command: <code>{{ s.command.command | e }}</code> [{{ s.run_time_ms }} ms]<br/>
                            </small>
                        </p>
                    {% endif %}
                </li>
        {%- endif %}
        {% endfor %}
        </ul>
        </details>
    {% endfor %}

    {% if flamegraph_svg %}
    <hr/>
    <h2>CPU Flamegraph</h2>
    <div style="overflow-x:auto;">
        {{ flamegraph_svg | safe }}
    </div>
    {% endif %}

    {%- if signals %}
    <hr/>
    <h2>Signals</h2>
    <table style="border-collapse:collapse;width:100%;margin-bottom:1rem;">
        <thead><tr>
            <th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">ID</th>
            <th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Value</th>
            <th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Trend</th>
            <th style="padding:0.4rem 0.8rem;border-bottom:2px solid #dee2e6;">Threshold</th>
        </tr></thead>
        <tbody>
        {%- for s in signals %}
        {%- set thr = signal_thresholds[s.id] %}
        <tr>
            <td style="padding:0.4rem 0.8rem;"><code>{{ s.id | e }}</code></td>
            <td style="padding:0.4rem 0.8rem;">{{ s.value | e }}</td>
            <td style="padding:0.4rem 0.8rem;">{{ s.stats.trend if s.stats else "—" }}</td>
            <td style="padding:0.4rem 0.8rem;">{% if thr %}{{ thr.op | e }} {{ thr.value }} ({{ thr.severity | e }}){% else %}—{% endif %}</td>
        </tr>
        {%- endfor %}
        </tbody>
    </table>
    {%- endif %}

    <hr/>

    <small>See <a
            href="https://medium.com/netflix-techblog/linux-performance-analysis-in-60-000-milliseconds-accc10403c55">Linux
        Performance Analysis in 60,000 Milliseconds</a> for details about the individual reports.</small>
    {%- if findings %}
    <p><strong>Tip:</strong> run <code>usereport diff &lt;before.json&gt; &lt;after.json&gt;</code> to compare two reports after remediating findings.</p>
    {%- endif %}
</div>
</body>
</html>
